# SimBrain 服务配置
# input_dir、output_dir 与 project 由 CLI 参数或 MCP 工具参数显式传入。

# ============================================================
# Embedding
# ============================================================
# "openai"（OpenAI 兼容接口）或 "ollama"（Ollama 原生 /api/embed）
EMBEDDING_PROVIDER=ollama
# OpenAI 兼容接口示例：https://your-embedding-api/v1
# Ollama 示例：http://localhost:11434
EMBEDDING_URL=http://localhost:11434
EMBEDDING_API_KEY=
EMBEDDING_MODEL=bge-m3
EMBEDDING_DIM=1024

# ============================================================
# Elasticsearch（ES_CLOUD_ID 与 ES_URL 二选一）
# ============================================================
# Elastic Cloud：填写 ES_CLOUD_ID，并将 ES_URL 留空。
ES_CLOUD_ID=
# 自建或其他云：填写 ES_URL，并将 ES_CLOUD_ID 留空。
ES_URL=
# ES_API_KEY 优先于 ES_USERNAME 与 ES_PASSWORD。
ES_API_KEY=
ES_USERNAME=elastic
ES_PASSWORD=
# 保留的物理索引版本数（当前版本包含在内）。
ES_INDEX_VERSIONS_TO_KEEP=2

# ============================================================
# MinerU 云 PDF OCR（可选；留空时 PDF 回退到 pypdf）
# ============================================================
MINERU_API_TOKEN=

# ============================================================
# 文本切片
# ============================================================
CHUNK_SIZE=512
CHUNK_OVERLAP=120

