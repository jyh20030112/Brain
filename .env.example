# ============================================================
# 输入输出
# ============================================================
INPUT_DIR=./docs/
PROJECT=省心说客服
OUTPUT_DIR=mvp_output

# ============================================================
# LLM (OpenAI 兼容接口)
# ============================================================
LLM_BASE_URL=http://your-llm-server:30000/v1
LLM_API_KEY=EMPTY
LLM_MODEL=glm-4.7

# ============================================================
# Embedding
# ============================================================
# "openai"（OpenAI 兼容接口）或 "ollama"（Ollama 原生 /api/embed）
EMBEDDING_PROVIDER=ollama
# Ollama: http://localhost:11434；OpenAI 兼容: 留空则使用 LLM_BASE_URL
EMBEDDING_URL=http://localhost:11434
EMBEDDING_MODEL=bge-m3
EMBEDDING_DIM=1024

# ============================================================
# Elasticsearch (Cloud ID / URL 二选一)
# ============================================================
# 方式1: Elastic Cloud（填 ES_CLOUD_ID，忽略 ES_URL）
ES_CLOUD_ID=
# 方式2: 其他云/自建（填 ES_URL，ES_CLOUD_ID 留空）
ES_URL=https://your-deployment.es.region.gcp.elastic.cloud:443
# 认证: API Key 优先于密码
ES_API_KEY=
ES_USERNAME=elastic
ES_PASSWORD=

# ============================================================
# MinerU 云 PDF OCR（可选，留空则用 pypdf 本地提取）
# ============================================================
# 从 https://mineru.net 获取
MINERU_API_TOKEN=

# ============================================================
# QA 生成参数
# ============================================================
QA_LIMIT=12
QA_GENERALIZATION=2
CHUNK_SIZE=512
CHUNK_OVERLAP=120
